{
  "name": "hein-luxury-erp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install-all": "npm install --workspace=frontend --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "start": "npm start --workspace=backend",
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
